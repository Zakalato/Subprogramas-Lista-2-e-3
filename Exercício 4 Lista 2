package lista2;

import java.text.DecimalFormat;
import java.util.ArrayList;
import java.util.Scanner;

/*
 * ESTA É A QUESTÃO 4 REFATORADA, CONFORME IMPLEMENTADO EM SALA DE AULA
 */

public class Questao5 {
	static Scanner s = new Scanner(System.in);
	static DecimalFormat df = new DecimalFormat("####0.00");
	static int quant10 = 0;
	static int quant15 = 0;
	static int quant20 = 0;
	static int quant25 = 0;
	static int quantFora = 0;
	static int somaFora = 0;
	static int contFora = 0;

	public static double calculaDiagonal(double l, double p, double a){
		double somaQuadrados = Math.pow(l, 2) + Math.pow(a, 2) + Math.pow(p, 2);
		double md = Math.sqrt(somaQuadrados);
		return md;
	}
	
	public static void selecionaEsfera(double maiorDiagonal, int quantBrinquedos){
		if (maiorDiagonal > 25){
			quantFora += quantBrinquedos;
			somaFora += maiorDiagonal;
			contFora++;
		}
		else
			if (maiorDiagonal > 20)
				quant25 += quantBrinquedos;
			else	
				if (maiorDiagonal > 15)
					quant20 += quantBrinquedos;
				else
					if (maiorDiagonal > 10)
						quant15 += quantBrinquedos;
					else
						quant10 += quantBrinquedos;
	}
	
	public static void imprime(){
		System.out.println("Quant. de brinquedos em esferas de 10cm: " + quant10);
		System.out.println("Quant. de brinquedos em esferas de 15cm: " + quant15);
		System.out.println("Quant. de brinquedos em esferas de 20cm: " + quant20);
		System.out.println("Quant. de brinquedos em esferas de 25cm: " + quant25);
		System.out.println("Quant. de brinquedos que não podem ser embalados: " + quantFora);
		System.out.println("Tam. médio das caixas que não serão embaladas: " 
		                    + df.format(somaFora/contFora));
		//System.out.println("O custo total de embalagem é:" ???
	}
	
	
	public static void processa(double larg, double prof, double alt, int quant){
		//Passo 2.1 : calcular maior diagonal		
		double maiorD = calculaDiagonal(larg, prof, alt);
		
		//Passo 2.2: Seleção da melhor esfera
		selecionaEsfera(maiorD, quant);		
	}
	public static void main(String[] args) {
		
		while (true){
			//Passo 1 : ler entradas
			System.out.println("Informe a medida da largura da caixa(-1 para terminar).");
			double larg = s.nextDouble();
			
			if (larg < 0)
				break;
			
			System.out.println("Informe a medida da altura da caixa");
			double alt = s.nextDouble();	
			
			System.out.println("Informe a medida da profundidade da caixa");
			double prof = s.nextDouble();
			
			System.out.println("Informe a quantidade de brinquedos deste lote");
			int quant = s.nextInt();
			
			//Passo 2: contabilizar esferas
			processa(larg, prof, alt, quant);
		}
		imprime();
	}
}
