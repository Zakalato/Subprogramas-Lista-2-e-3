package Lista_2;

import java.util.Scanner;
public class Exercicio_2 {
    static Scanner s = new Scanner(System.in);
    
    public static String perfeito(int num) {
    	int soma = 0;
    	String lista = "";
    for(int i = 1; i < num ; i++) 
    	if(num % i == 0) {
    		soma += i;
    		lista = lista + " " + i;
    	}
    
    	if (soma == num)
    		return"É numero perfeito. Lista dos divisores: " + lista;
    	return "Não é número perfeito";
    	
    }
    
	public static void main(String[] args) {
		System.out.println("Digite seu número");
		int num = s.nextInt();
		System.out.println(perfeito(num));

	}

}
